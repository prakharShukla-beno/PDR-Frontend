# Server-side Next.js proxy target (rewrites /api → backend)
BACKEND_URL=http://localhost:5000

# Browser file uploads bypass Vercel proxy — must be public
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# Production example:
# BACKEND_URL=https://pdr-backend-5c2y.onrender.com
# NEXT_PUBLIC_BACKEND_URL=https://pdr-backend-5c2y.onrender.com
